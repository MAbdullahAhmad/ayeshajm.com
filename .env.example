# Active app mode for local routing experiments.
# true  -> enable dev-only pages/routes
# false -> keep dev-only pages out of the router
VITE_ENABLE_DEV_ROUTES=false

# Default theme applied on first load when no stored preference exists.
# Supported values in the current setup:
# light
# dark
VITE_THEME_DEFAULT=light

# Time-to-live in milliseconds for cached non-home routes after the user leaves them.
# Home is never evicted during the current SPA session.
# Set to 30000 for the requested 30-second lazy-route reset behavior.
VITE_ROUTE_CACHE_TTL_MS=30000
